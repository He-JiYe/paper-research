{
    "llm": {
        "provider": "deepseek",
        "model": "deepseek-v4-flash",
        "api_base": "https://api.deepseek.com",
        "api_key": "YOUR_DEEPSEEK_API_KEY_HERE",
        "temperature": 0.3,
        "max_tokens": 5000
    },
    "fetch": {
        "source": "arxiv",
        "max_concurrent_requests": 5,
        "lookback_days": 3,
        "max_results": 25,
        "user_agent": "PaperResearch/1.0"
    },
    "server": {
        "host": "127.0.0.1",
        "port": 8899
    },
    "notification": {
        "windows_toast": true,
        "email": {
            "enabled": false,
            "smtp_host": "",
            "smtp_port": 465,
            "username": "",
            "password": "",
            "from": "",
            "to": ""
        }
    },
    "scoring": {
        "min_relevance_score": 0.3
    }
}

